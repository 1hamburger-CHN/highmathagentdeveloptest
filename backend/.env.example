# === 苏格拉底教练 2.0 — 环境变量配置 ===
# 复制此文件为 .env 并填入实际值

# 讯飞 Spark API (HTTP REST)
SPARK_API_PASSWORD=

# DeepSeek API (OpenAI 兼容)
DEEPSEEK_API_KEY=

# 讯飞 Spark 图片理解 API (WebSocket)
SPARK_IMAGE_APP_ID=
SPARK_IMAGE_API_KEY=
SPARK_IMAGE_API_SECRET=

# Turso 数据库 (libsql/SQLite)
TURSO_URL=
TURSO_TOKEN=

# ChromaDB 向量数据库存储路径 (默认: data/chromadb)
# CHROMA_PERSIST_DIR=

# Embedding 模型 (默认: sentence-transformers/all-MiniLM-L6-v2)
# EMBEDDING_MODEL=

# HuggingFace 镜像 (国内用户)
# HF_ENDPOINT=https://hf-mirror.com
